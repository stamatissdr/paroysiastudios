---
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<section class="relative bg-charcoal text-cloud overflow-hidden">
  <!-- Background abstract symbols -->
  <div id="hero-symbols" class="absolute inset-0 pointer-events-none select-none" style="z-index: 0;"></div>

  <!-- Sticky Logo Section -->
  <div class="sticky top-0 h-screen flex items-center justify-center z-10 bg-charcoal">
    <div class="text-center">
      <h1 class="text-5xl md:text-8xl text-cloud" style="font-weight: 300; letter-spacing: 0.15em; text-transform: uppercase;">
        PAROYSIA
      </h1>
      <div class="mt-6 flex justify-center gap-2">
        <span class="w-3 h-3 rounded-full" style="background-color: #388E4F"></span>
      </div>
    </div>
  </div>

  <!-- Welcome Section -->
  <div class="relative bg-charcoal text-cloud fade-in-on-scroll py-24 px-8 md:px-16" style="opacity: 0; position: relative; z-20;">
    <div class="max-w-5xl mx-auto space-y-20">

      <!-- 1: Large, left -->
      <p class="fade-para text-4xl md:text-6xl font-light text-cloud leading-tight max-w-2xl">
        Οι περισσότερες μικρές επιχειρήσεις είναι αόρατες online.
      </p>

      <!-- 2: Small, right -->
      <p class="fade-para text-base md:text-lg text-slate leading-relaxed max-w-sm ml-auto text-right">
        Όχι γιατί δεν αξίζουν — γιατί κανείς δεν τους έδειξε πώς να φανούν.
      </p>

      <!-- 3: Medium, left -->
      <p class="fade-para text-xl md:text-2xl text-slate leading-relaxed max-w-xl">
        Έχτισες την επιχείρησή σου με κόπο, αφιέρωση και αληθινές σχέσεις.
      </p>

      <!-- 4: Large, right, cloud -->
      <p class="fade-para text-2xl md:text-4xl font-semibold text-cloud leading-snug max-w-xl ml-auto text-right">
        Αλλά όταν κάποιος ψάχνει αυτό που κάνεις, βρίσκει τον διπλανό σου — όχι εσένα.
      </p>

      <!-- 5: Small, left, italic -->
      <p class="fade-para text-sm md:text-base text-slate italic leading-relaxed max-w-md">
        Μπορεί να σου είπαν ότι χρειάζεσαι ιστοσελίδα €3.000. Μπορεί κάποιο agency να σου υποσχέθηκε αποτελέσματα και να σου έστειλε στο τέλος αριθμούς που δεν σήμαιναν τίποτα. Ή μπορεί να έφτιαξες Facebook page και το παράτησες μετά από μια εβδομάδα.
      </p>

      <!-- 6: XL, center, bold -->
      <p class="fade-para text-3xl md:text-5xl font-black text-cloud text-center leading-tight">
        Δεν έχεις μείνει πίσω.<br/>Απλά δεν είχες ακόμα τον σωστό συνεργάτη.
      </p>

      <!-- 7: Medium, right -->
      <p class="fade-para text-lg md:text-xl text-slate leading-relaxed max-w-lg ml-auto text-right">
        Η Paroysia υπάρχει για έναν λόγο: να δώσει στην επιχείρησή σου την online παρουσία που της αξίζει — χωρίς αόριστες υποσχέσεις, χωρίς φουσκωμένα πακέτα.
      </p>

      <!-- 8: Medium, left -->
      <p class="fade-para text-lg md:text-xl text-slate leading-relaxed max-w-lg">
        Δεν πουλάμε φαντασία. Κοιτάμε πού βρίσκεσαι τώρα, σου δείχνουμε τι λείπει και φτιάχνουμε ακριβώς αυτό που χρειάζεσαι.
      </p>

      <!-- CTA -->
      <div class="fade-para pt-4 flex flex-col items-center text-center">
        <p class="text-sm text-slate italic mb-6">
          Ξεκίνα με δωρεάν αξιολόγηση. Σε 30 λεπτά θα ξέρεις ακριβώς πού στέκεσαι — και τι χρειάζεται για να σε βρίσκουν.
        </p>
        <a href={`${base}/el/free-audit`} class="inline-block bg-primary text-white px-8 py-4 rounded font-semibold hover:bg-deepgreen transition-colors text-lg">
          Κάντε Δωρεάν Αξιολόγηση →
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  // Generate abstract background symbols
  const symbolChars = [
    '→', '←', '↑', '↓', '↗', '↙', '↘', '↖',
    '✓', '✗', '×', '+',
    '{', '}', '[', ']', '()', '<>',
    '//', '</', '/>',
    '#', '@', '~', '•', '◦', '°', '∞',
    ';)', ':/', ':D', ':|',
    '—', '_', '**', '01', '10',
  ];
  const container = document.getElementById('hero-symbols');
  if (container) {
    for (let i = 0; i < 65; i++) {
      const span = document.createElement('span');
      const sym = symbolChars[Math.floor(Math.random() * symbolChars.length)];
      const isGreen = Math.random() > 0.55;
      const opacity = (Math.random() * 0.09 + 0.03).toFixed(2);
      const color = isGreen
        ? `rgba(56,142,79,${opacity})`
        : `rgba(217,222,227,${opacity})`;
      const size = Math.floor(Math.random() * 12 + 10);
      const x = (Math.random() * 96 + 1).toFixed(1);
      const y = (Math.random() * 96 + 1).toFixed(1);
      const rotate = (Math.random() * 70 - 35).toFixed(1);
      span.textContent = sym;
      span.style.cssText = `
        position: absolute;
        left: ${x}%;
        top: ${y}%;
        font-size: ${size}px;
        color: ${color};
        transform: rotate(${rotate}deg);
        font-family: monospace;
        line-height: 1;
        white-space: nowrap;
      `;
      container.appendChild(span);
    }
  }

  const welcomeSection = document.querySelector('.fade-in-on-scroll') as HTMLElement;
  const paras = Array.from(document.querySelectorAll('.fade-para')) as HTMLElement[];

  function update() {
    const scrollY = window.scrollY;
    const wh = window.innerHeight;

    // Section fade-in as you scroll past sticky hero
    if (welcomeSection) {
      const sectionOpacity = Math.max(0, Math.min(1, (scrollY - wh * 0.1) / (wh * 0.25)));
      welcomeSection.style.opacity = sectionOpacity.toString();
    }

    // Each paragraph: fade in based on how far it has scrolled into view
    paras.forEach(p => {
      const rect = p.getBoundingClientRect();
      // Start fading when element top reaches 90% down the screen, fully visible at 55%
      const progress = Math.max(0, Math.min(1, (wh * 0.9 - rect.top) / (wh * 0.35)));
      p.style.opacity = progress.toString();
      p.style.transform = `translateY(${(1 - progress) * 28}px)`;
    });
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
</script>

<style is:global>
  .fade-para {
    opacity: 0;
    transform: translateY(28px);
  }
</style>
