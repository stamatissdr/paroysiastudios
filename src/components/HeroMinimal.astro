---
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<section class="relative bg-charcoal text-cloud overflow-hidden">
  <!-- Sticky Logo Section -->
  <div class="sticky top-0 h-screen flex items-center justify-center z-10 bg-charcoal">
    <div class="text-center">
      <h1 class="text-5xl md:text-8xl text-cloud" style="font-weight: 300; letter-spacing: 0.15em; text-transform: uppercase;">
        PAROYSIA
      </h1>
      <div class="mt-6 flex justify-center gap-2">
        <span class="w-3 h-3 rounded-full" style="background-color: #388E4F"></span>
      </div>
    </div>
  </div>

  <!-- Welcome Section -->
  <div class="relative bg-charcoal text-cloud fade-in-on-scroll py-24 px-8 md:px-16" style="opacity: 0; position: relative; z-20;">
    <div class="max-w-5xl mx-auto space-y-20">

      <!-- 1: Large, left -->
      <p class="fade-para text-4xl md:text-6xl font-light text-cloud leading-tight max-w-2xl">
        Most small businesses are invisible online.
      </p>

      <!-- 2: Small, right -->
      <p class="fade-para text-base md:text-lg text-slate leading-relaxed max-w-sm ml-auto text-right">
        Not because they're bad at what they do — because nobody ever showed them how to be found.
      </p>

      <!-- 3: Medium, left -->
      <p class="fade-para text-xl md:text-2xl text-slate leading-relaxed max-w-xl">
        You built your business with hard work, long hours, and real relationships.
      </p>

      <!-- 4: Large, right, cloud -->
      <p class="fade-para text-2xl md:text-4xl font-semibold text-cloud leading-snug max-w-xl ml-auto text-right">
        But when someone searches for what you offer, they find your competitor — not you.
      </p>

      <!-- 5: Small, left, italic -->
      <p class="fade-para text-sm md:text-base text-slate italic leading-relaxed max-w-md">
        Maybe you've been told you need a €3,000 website. Maybe an agency promised results and sent you a report full of numbers that meant nothing. Maybe you set up a Facebook page, posted for a week, and never touched it again.
      </p>

      <!-- 6: XL, center, bold -->
      <p class="fade-para text-3xl md:text-5xl font-black text-cloud text-center leading-tight">
        You're not behind.<br/>You just haven't had the right partner.
      </p>

      <!-- 7: Medium, right -->
      <p class="fade-para text-lg md:text-xl text-slate leading-relaxed max-w-lg ml-auto text-right">
        Paroysia exists for one reason: to give your business the online presence it deserves — without the jargon, without the overpriced packages.
      </p>

      <!-- 8: Medium, left -->
      <p class="fade-para text-lg md:text-xl text-slate leading-relaxed max-w-lg">
        We don't sell dreams. We look at where you are, show you what's missing, and build only what you actually need.
      </p>

      <!-- CTA -->
      <div class="fade-para pt-4 flex flex-col items-center text-center">
        <p class="text-sm text-slate italic mb-6">
          Start with a free audit. In 30 minutes, you'll see exactly where you stand — and what it takes to be found.
        </p>
        <a href={`${base}/free-audit`} class="inline-block bg-primary text-white px-8 py-4 rounded font-semibold hover:bg-deepgreen transition-colors text-lg">
          Get Your Free Audit →
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  const welcomeSection = document.querySelector('.fade-in-on-scroll') as HTMLElement;
  const paras = Array.from(document.querySelectorAll('.fade-para')) as HTMLElement[];

  function update() {
    const scrollY = window.scrollY;
    const wh = window.innerHeight;

    // Section fade-in as you scroll past sticky hero
    if (welcomeSection) {
      const sectionOpacity = Math.max(0, Math.min(1, (scrollY - wh * 0.1) / (wh * 0.25)));
      welcomeSection.style.opacity = sectionOpacity.toString();
    }

    // Each paragraph: fade in based on how far it has scrolled into view
    paras.forEach(p => {
      const rect = p.getBoundingClientRect();
      // Start fading when element top reaches 90% down the screen, fully visible at 55%
      const progress = Math.max(0, Math.min(1, (wh * 0.9 - rect.top) / (wh * 0.35)));
      p.style.opacity = progress.toString();
      p.style.transform = `translateY(${(1 - progress) * 28}px)`;
    });
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
</script>

<style is:global>
  .fade-para {
    opacity: 0;
    transform: translateY(28px);
  }
</style>
