---
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const { lang = 'en' } = Astro.props
const isEl = lang === 'el'
const p = isEl ? `${base}/el` : base

const nav = isEl
  ? { services: 'Υπηρεσίες', portfolio: 'Έργα', about: 'Σχετικά', contact: 'Επικοινωνία', audit: 'Δωρεάν Αξιολόγηση' }
  : { services: 'Services', portfolio: 'Portfolio', about: 'About', contact: 'Contact', audit: 'Free Audit' }
---
<header class="bg-charcoal border-b border-slate/20 sticky top-0 z-50">
  <div class="max-w-screen-2xl mx-auto px-6 xl:px-12 2xl:px-20 py-4 xl:py-5 flex items-center justify-between">
    <a href={`${p}/`}>
      <img src="/logo.png" alt="Paroysia" class="h-8 xl:h-10 2xl:h-12 w-auto" />
    </a>

    <nav class="hidden md:flex items-center gap-8 xl:gap-12 text-sm xl:text-base">
      <a href={`${p}/services`} class="text-cloud hover:text-primary transition-colors">{nav.services}</a>
      <a href={`${p}/portfolio`} class="text-cloud hover:text-primary transition-colors">{nav.portfolio}</a>
      <a href={`${p}/about`} class="text-cloud hover:text-primary transition-colors">{nav.about}</a>
      <a href={`${p}/contact`} class="text-cloud hover:text-primary transition-colors">{nav.contact}</a>
      <a href={`${p}/free-audit`} class="ml-4 inline-block bg-primary text-white px-5 py-2 rounded font-semibold hover:bg-deepgreen transition-colors">{nav.audit}</a>
      <!-- Language toggle -->
      {isEl
        ? <a href={`${base}/`} class="ml-2 text-slate hover:text-cloud text-xs uppercase tracking-widest transition-colors border border-slate/30 hover:border-cloud/50 px-2 py-1 rounded">EN</a>
        : <a href={`${base}/el/`} class="ml-2 text-slate hover:text-cloud text-xs uppercase tracking-widest transition-colors border border-slate/30 hover:border-cloud/50 px-2 py-1 rounded">ΕΛ</a>
      }
    </nav>

    <button id="mobile-menu-btn" class="md:hidden p-2 hover:bg-slate/20 rounded text-cloud" aria-label="Open menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate/20 bg-charcoal px-6 py-4 flex flex-col gap-4 text-sm">
    <a href={`${p}/services`} class="text-cloud hover:text-primary transition-colors py-1">{nav.services}</a>
    <a href={`${p}/portfolio`} class="text-cloud hover:text-primary transition-colors py-1">{nav.portfolio}</a>
    <a href={`${p}/about`} class="text-cloud hover:text-primary transition-colors py-1">{nav.about}</a>
    <a href={`${p}/contact`} class="text-cloud hover:text-primary transition-colors py-1">{nav.contact}</a>
    <a href={`${p}/free-audit`} class="inline-block bg-primary text-white px-5 py-3 rounded font-semibold text-center hover:bg-deepgreen transition-colors">{nav.audit}</a>
    {isEl
      ? <a href={`${base}/`} class="text-slate text-xs uppercase tracking-widest py-1">EN</a>
      : <a href={`${base}/el/`} class="text-slate text-xs uppercase tracking-widest py-1">ΕΛ</a>
    }
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
