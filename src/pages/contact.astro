---
import Layout from '../components/Layout.astro'
---
<Layout seo={{ title: 'Contact', description: 'Get in touch with Paroysia.' }}>
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold text-charcoal">Contact</h1>
    <p class="text-slate mt-4">Reach out with any questions or to start your free audit.</p>

    <div class="mt-8 grid md:grid-cols-2 gap-6">
      <div class="bg-white p-6 rounded">
        <h3 class="font-bold text-charcoal">Email</h3>
        <a href="mailto:sidiras.stamatis@gmail.com" class="text-primary mt-2 block">sidiras.stamatis@gmail.com</a>
      </div>
      <div class="bg-white p-6 rounded">
        <h3 class="font-bold text-charcoal">Location</h3>
        <p class="text-slate mt-2">Thessaloniki, Greece</p>
      </div>
    </div>

    <form action="https://formspree.io/f/xreynbzl" method="POST" class="mt-8 grid gap-4 bg-white p-6 rounded">
      <label class="block">
        <span class="font-semibold text-charcoal">Name</span>
        <input name="name" placeholder="Your name" class="w-full mt-1 p-3 border rounded border-cloud" required />
      </label>
      <label class="block">
        <span class="font-semibold text-charcoal">Email</span>
        <input name="email" placeholder="Email" class="w-full mt-1 p-3 border rounded border-cloud" required />
      </label>
      <label class="block">
        <span class="font-semibold text-charcoal">Phone</span>
        <input name="phone" placeholder="Phone" class="w-full mt-1 p-3 border rounded border-cloud" />
      </label>
      <label class="block">
        <span class="font-semibold text-charcoal">Message</span>
        <textarea name="message" placeholder="Tell us about your business..." rows="5" class="w-full mt-1 p-3 border rounded border-cloud"></textarea>
      </label>
      <button class="bg-primary text-white px-4 py-3 rounded font-semibold hover:opacity-90">Send Message</button>
    </form>
  </section>
</Layout>
