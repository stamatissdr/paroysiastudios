---
import Layout from '../../components/Layout.astro'
---
<Layout lang="el" seo={{ title: 'Επικοινωνία', description: 'Επικοινώνησε με την Paroysia.' }}>
  <section class="max-w-2xl mx-auto px-6 xl:px-12 py-16">
    <h1 class="text-3xl font-bold text-charcoal">Επικοινωνία</h1>
    <p class="text-slate mt-4">Επικοινώνησε για οποιαδήποτε απορία ή για να ξεκινήσεις τη δωρεάν αξιολόγησή σου.</p>

    <div class="mt-8 grid md:grid-cols-2 gap-6">
      <div class="bg-white p-6 rounded">
        <h3 class="font-bold text-charcoal">Email</h3>
        <a href="mailto:sidiras.stamatis@gmail.com" class="text-primary mt-2 block">sidiras.stamatis@gmail.com</a>
      </div>
      <div class="bg-white p-6 rounded">
        <h3 class="font-bold text-charcoal">Τοποθεσία</h3>
        <p class="text-slate mt-2">Θεσσαλονίκη, Ελλάδα</p>
      </div>
    </div>

    <form action="https://formspree.io/f/xreynbzl" method="POST" class="mt-8 grid gap-4 bg-white p-6 rounded">
      <label class="block">
        <span class="font-semibold text-charcoal">Όνομα</span>
        <input name="name" placeholder="Το όνομά σου" class="w-full mt-1 p-3 border rounded border-cloud" required />
      </label>
      <label class="block">
        <span class="font-semibold text-charcoal">Email</span>
        <input name="email" placeholder="Email" class="w-full mt-1 p-3 border rounded border-cloud" required />
      </label>
      <label class="block">
        <span class="font-semibold text-charcoal">Τηλέφωνο</span>
        <input name="phone" placeholder="Τηλέφωνο" class="w-full mt-1 p-3 border rounded border-cloud" />
      </label>
      <label class="block">
        <span class="font-semibold text-charcoal">Μήνυμα</span>
        <textarea name="message" placeholder="Πες μας για την επιχείρησή σου..." rows="5" class="w-full mt-1 p-3 border rounded border-cloud"></textarea>
      </label>
      <button class="bg-primary text-white px-4 py-3 rounded font-semibold hover:opacity-90">Αποστολή</button>
    </form>
  </section>
</Layout>
