---
import Layout from '../../components/Layout.astro'
import ServiceCard from '../../components/ServiceCard.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Layout lang="el" seo={{ title: 'Υπηρεσίες', description: 'Πλάνα και τιμές. Θεμέλιο, Ανάπτυξη, και Κύρος.' }}>
  <div class="max-w-6xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-bold text-cloud text-center">Υπηρεσίες</h1>
    <p class="hidden md:block text-slate mt-4 text-lg text-center">Κρατήστε τον κέρσορα πάνω σε κάθε πλάνο για να δείτε τι περιλαμβάνει.</p>

    <!-- Carousel wrapper -->
    <div class="carousel-wrapper mt-12 relative group/carousel">
      <!-- Arrows -->
      <button class="carousel-prev absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 z-10 opacity-0 group-hover/carousel:opacity-100 transition-opacity duration-300 text-cloud/50 hover:text-cloud text-3xl px-2 py-4 select-none">‹</button>
      <button class="carousel-next absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 z-10 opacity-0 group-hover/carousel:opacity-100 transition-opacity duration-300 text-cloud/50 hover:text-cloud text-3xl px-2 py-4 select-none">›</button>

      <!-- Viewport -->
      <div class="carousel-viewport overflow-hidden">
        <div class="carousel-track flex transition-transform duration-700 ease-in-out will-change-transform">
          <div class="carousel-item flex-shrink-0 w-full">
            <ServiceCard
              title="Θεμέλιο"
              features={[
                "Δημιουργία Google Business",
                "Μονοσέλιδη ιστοσελίδα",
                "Βασικό τοπικό SEO",
                "Εκκαθάριση social media",
                "Ρύθμιση email"
              ]}
            />
          </div>
          <div class="carousel-item flex-shrink-0 w-full">
            <ServiceCard
              title="Ανάπτυξη"
              features={[
                "Πλήρης ιστοσελίδα (5-10 σελίδες)",
                "Ρύθμιση Google Ads",
                "Προηγμένο τοπικό SEO",
                "Σύστημα διαχείρισης κριτικών",
                "Πρότυπα περιεχομένου",
                "Μηνιαία βελτιστοποίηση"
              ]}
            />
          </div>
          <div class="carousel-item flex-shrink-0 w-full">
            <ServiceCard
              title="Κύρος"
              features={[
                "Πλήρες ψηφιακό οικοσύστημα",
                "Προηγμένη στρατηγική SEO",
                "Αυτοματισμός email marketing",
                "Επαγγελματική φωτογράφηση",
                "Παρακολούθηση ανταγωνιστών",
                "Μηνιαία αναφορά",
                "Προτεραιότητα υποστήριξης"
              ]}
            />
          </div>
        </div>
      </div>
    </div>

    <script>
      const wrapper = document.querySelector('.carousel-wrapper') as HTMLElement;
      const track = document.querySelector('.carousel-track') as HTMLElement;
      const items = document.querySelectorAll('.carousel-item');
      const prevBtn = document.querySelector('.carousel-prev') as HTMLButtonElement;
      const nextBtn = document.querySelector('.carousel-next') as HTMLButtonElement;

      let current = 0;
      let paused = false;
      let scrollCooldown = false;

      function getOffset(index: number): number {
        return (items[index] as HTMLElement).offsetLeft;
      }

      function goTo(index: number) {
        current = (index + items.length) % items.length;
        track.style.transform = `translateX(-${getOffset(current)}px)`;
      }

      setInterval(() => { if (!paused) goTo(current + 1); }, 3000);

      prevBtn.addEventListener('click', () => goTo(current - 1));
      nextBtn.addEventListener('click', () => goTo(current + 1));

      wrapper.addEventListener('mouseenter', () => { paused = true; });
      wrapper.addEventListener('mouseleave', () => { paused = false; });

      wrapper.addEventListener('wheel', (e: WheelEvent) => {
        if (!paused) return;
        const isHorizontal = Math.abs(e.deltaX) > Math.abs(e.deltaY);
        if (!isHorizontal) return;
        e.preventDefault();
        if (scrollCooldown) return;
        scrollCooldown = true;
        setTimeout(() => { scrollCooldown = false; }, 800);
        if (e.deltaX > 10) goTo(current + 1);
        else if (e.deltaX < -10) goTo(current - 1);
      }, { passive: false });
    </script>

    <section class="mt-20 text-center">
      <h2 class="text-3xl font-bold text-cloud">Έτοιμος να ξεκινήσεις;</h2>
      <p class="text-slate mt-4">Κάθε πλάνο προσαρμόζεται στις ανάγκες της επιχείρησής σου. Ας βρούμε αυτό που σου ταιριάζει.</p>
      <div class="mt-8">
        <a href={`${base}/el/free-audit`} class="inline-block bg-primary text-white px-8 py-4 rounded font-semibold hover:bg-deepgreen transition-colors">
          Ζήτα Δωρεάν Αξιολόγηση
        </a>
      </div>
    </section>
  </div>
</Layout>
