---
import Layout from '../components/Layout.astro'
---
<Layout seo={{ title: 'Not found', description: '404 Page not found' }}>
  <section class="max-w-4xl mx-auto px-6 py-20 text-center">
    <h1 class="text-4xl font-bold text-charcoal">404 — Page not found</h1>
    <p class="mt-4 text-slate">Sorry, we couldn't find that page.</p>
    <a href="/" class="mt-6 inline-block bg-primary text-white px-4 py-2 rounded">Back home</a>
  </section>
</Layout>
