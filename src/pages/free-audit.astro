---
import Layout from '../components/Layout.astro'
---
<Layout seo={{ title: 'Free Audit', description: 'Free 30-minute audit — local presence review.' }}>
  <section class="max-w-3xl mx-auto px-6 py-16 bg-white rounded">
    <h1 class="text-2xl font-bold text-charcoal">Is your business invisible online? Find out in 30 minutes — free.</h1>
    <p class="text-slate mt-4">We check your Google presence, website, social media, and competitors. No commitment.</p>
    <form action="https://formspree.io/f/xreynbzl" method="POST" class="mt-6 grid gap-4">
      <input name="name" placeholder="Your name" class="p-3 border rounded" required />
      <input name="business" placeholder="Business name" class="p-3 border rounded" />
      <input name="email" placeholder="Email" class="p-3 border rounded" required />
      <input name="phone" placeholder="Phone" class="p-3 border rounded" />
      <select name="business_type" class="p-3 border rounded">
        <option>Retail</option>
        <option>Food & Drink</option>
        <option>Professional Service</option>
        <option>Other</option>
      </select>
      <button class="bg-primary text-white px-4 py-2 rounded">Request Free Audit</button>
    </form>
  </section>
</Layout>
